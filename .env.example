# zrok Token para ativação do ambiente (Obrigatório para o primeiro run)
# Pode ser obtido em https://zrok.io/
ZROK_TOKEN=seu_token_aqui

# Modo do túnel zrok (public|private)
TUNNEL_ZROK_MODE=public

# Alvo interno do túnel (normalmente o Caddy local)
TUNNEL_ZROK_TARGET=http://127.0.0.1:80

# Base pública do zrok para os shares
TUNNEL_ZROK_PUBLIC_BASE=shares.zrok.io

# Nome da instância (subdomínio reservado)
# Resultará em: instancia.shares.zrok.io
TUNNEL_ZROK_INSTANCE_NAME=minha-instancia

# Args extras opcionais para `zrok share`
TUNNEL_ZROK_EXTRA_ARGS=--headless

# Configuração de serviços para o Caddy
# O módulo usará os valores abaixo se definidos, caso contrário usará os padrões do Nix
SERVICE_HAT_PATH=/hat/
SERVICE_HAT_PROXY=localhost:20001

# Outras variáveis de ambiente opcionais do zrok (exemplo)
# ZROK_API_ENDPOINT=https://api.zrok.io
# ZROK_ENVIRONMENT_NAME=meu-tunnel-nixos
